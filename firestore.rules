rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - id: string (required) - Unique identifier for the project.
    //   - uid: string (required) - The user ID of the owner.
    //   - name: string (required) - Name of the project.
    //   - lastModified: number (required) - Timestamp of last modification.
    //   - settings: string (required) - JSON stringified settings.
    //   - pages: string (required) - JSON stringified pages.
    //   - thumbnail: string (optional) - Thumbnail image base64.
    //
    // Collection: allowedEmails
    // Document ID: {emailId} (The email address itself)
    // Fields:
    //   - email: string (required)
    //   - role: string (required) - 'admin' or 'user'
    //   - addedBy: string (required)
    //   - createdAt: number (required)
    //
    // Collection: userStyles
    // Document ID: {styleId}
    // Fields:
    //   - id: string (required)
    //   - uid: string (required)
    //   - name: string (required)
    //   - image: string (required)
    //   - prompt: string (required)
    //   - createdAt: number (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - tierId: string (required)
    //   - credits: number (required)
    //   - role: string (required)
    //
    // Collection: tiers
    // Document ID: {tierId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - maxProjects: number (required)
    //   - monthlyCredits: number (required)
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'hypocritic2002@gmail.com' ||
        (exists(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email)).data.role == 'admin')
      );
    }
    
    // Check if user is owner based on document's uid field
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    // Verify UID hasn't been tampered with on create
    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }
    
    // Ensure uid field is not modified on update
    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }
    
    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUserStyle(data) {
      let allowedFields = ['id', 'uid', 'name', 'image', 'prompt', 'createdAt'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['id', 'uid', 'name', 'image', 'prompt', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.image is string && data.image.size() < 1048576 && // 1MB limit
             data.prompt is string && data.prompt.size() < 1048576 && // 1MB limit
             data.createdAt is number;
    }

    function isValidProject(data) {
      let allowedFields = ['id', 'uid', 'name', 'lastModified', 'settings', 'pages', 'thumbnail', 'currentStep', 'fullScript', 'activityScript', 'nicheTopic', 'nicheResult', 'coverImage', 'coverLayers', 'projectContext', 'enableActivityDesigner', 'globalFixPrompt', 'targetAspectRatio', 'targetResolution'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['id', 'uid', 'name', 'lastModified', 'settings', 'pages']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.lastModified is number &&
             data.settings is string && data.settings.size() < 1048576 && // 1MB limit
             data.pages is string && data.pages.size() < 1048576 && // 1MB limit
             (!('thumbnail' in data) || data.thumbnail == null || (data.thumbnail is string && data.thumbnail.size() < 1048576)) &&
             (!('currentStep' in data) || data.currentStep == null || (data.currentStep is string && data.currentStep.size() < 100)) &&
             (!('fullScript' in data) || data.fullScript == null || (data.fullScript is string && data.fullScript.size() < 1048576)) &&
             (!('activityScript' in data) || data.activityScript == null || (data.activityScript is string && data.activityScript.size() < 1048576)) &&
             (!('nicheTopic' in data) || data.nicheTopic == null || (data.nicheTopic is string && data.nicheTopic.size() < 1000)) &&
             (!('nicheResult' in data) || data.nicheResult == null || (data.nicheResult is string && data.nicheResult.size() < 1048576)) &&
             (!('coverImage' in data) || data.coverImage == null || (data.coverImage is string && data.coverImage.size() < 1048576)) &&
             (!('coverLayers' in data) || data.coverLayers == null || (data.coverLayers is string && data.coverLayers.size() < 1048576)) &&
             (!('projectContext' in data) || data.projectContext == null || (data.projectContext is string && data.projectContext.size() < 1048576)) &&
             (!('enableActivityDesigner' in data) || data.enableActivityDesigner == null || data.enableActivityDesigner is bool) &&
             (!('globalFixPrompt' in data) || data.globalFixPrompt == null || (data.globalFixPrompt is string && data.globalFixPrompt.size() < 1048576)) &&
             (!('targetAspectRatio' in data) || data.targetAspectRatio == null || (data.targetAspectRatio is string && data.targetAspectRatio.size() < 100)) &&
             (!('targetResolution' in data) || data.targetResolution == null || (data.targetResolution is string && data.targetResolution.size() < 100));
    }

    function isValidAllowedEmail(data) {
      let allowedFields = ['email', 'role', 'tierId', 'addedBy', 'createdAt'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['email', 'role', 'addedBy', 'createdAt']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 200 &&
             data.role in ['admin', 'user'] &&
             (!('tierId' in data) || data.tierId == null || (data.tierId is string && data.tierId.size() < 100)) &&
             data.addedBy is string && data.addedBy.size() > 0 && data.addedBy.size() < 100 &&
             data.createdAt is number;
    }

    function isValidUserProfile(data) {
      let allowedFields = ['uid', 'email', 'tierId', 'credits', 'role'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['uid', 'email', 'tierId', 'credits', 'role']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 200 &&
             data.tierId is string && data.tierId.size() > 0 && data.tierId.size() < 100 &&
             data.credits is number && data.credits >= 0 &&
             data.role in ['admin', 'user'];
    }

    function isValidTier(data) {
      let allowedFields = ['id', 'name', 'maxProjects', 'monthlyCredits'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['id', 'name', 'maxProjects', 'monthlyCredits']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.maxProjects is number && data.maxProjects >= 0 &&
             data.monthlyCredits is number && data.monthlyCredits >= 0;
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() && isValidProject(request.resource.data) && uidUnchanged() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidProject(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /userStyles/{styleId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() && isValidUserStyle(request.resource.data) && uidUnchanged() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidUserStyle(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /allowedEmails/{emailId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.token.email == emailId);
      allow create: if isAdmin() && isValidAllowedEmail(request.resource.data) && request.resource.data.email == emailId;
      allow update: if isAdmin() && isValidAllowedEmail(request.resource.data) && request.resource.data.email == emailId && request.resource.data.email == resource.data.email;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
      allow create: if isAuthenticated() && isValidUserProfile(request.resource.data) && request.resource.data.uid == userId && (
        isAdmin() || 
        (request.resource.data.role == 'user' && request.resource.data.credits <= 10 && request.resource.data.tierId == 'free')
      );
      allow update: if isAuthenticated() && isValidUserProfile(request.resource.data) && request.resource.data.uid == userId && request.resource.data.uid == resource.data.uid && (
        isAdmin() ||
        (request.auth.uid == userId && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.tierId == resource.data.tierId && 
         request.resource.data.email == resource.data.email &&
         request.resource.data.credits <= resource.data.credits) // User can only decrement credits
      );
      allow delete: if isAdmin();
    }

    match /tiers/{tierId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidTier(request.resource.data) && request.resource.data.id == tierId;
      allow update: if isAdmin() && isValidTier(request.resource.data) && request.resource.data.id == tierId && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
