rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - id: string (required) - Unique identifier for the project.
    //   - uid: string (required) - The user ID of the owner.
    //   - name: string (required) - Name of the project.
    //   - lastModified: number (required) - Timestamp of last modification.
    //   - settings: string (required) - JSON stringified settings.
    //   - pages: string (required) - JSON stringified pages.
    //   - thumbnail: string (optional) - Thumbnail image base64.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is owner based on document's uid field
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    // Verify UID hasn't been tampered with on create
    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }
    
    // Ensure uid field is not modified on update
    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }
    
    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidProject(data) {
      let allowedFields = ['id', 'uid', 'name', 'lastModified', 'settings', 'pages', 'thumbnail', 'currentStep', 'fullScript', 'activityScript', 'nicheTopic', 'nicheResult', 'coverImage', 'coverLayers', 'projectContext', 'enableActivityDesigner', 'globalFixPrompt', 'targetAspectRatio', 'targetResolution'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['id', 'uid', 'name', 'lastModified', 'settings', 'pages']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.lastModified is number &&
             data.settings is string && data.settings.size() < 1048576 && // 1MB limit
             data.pages is string && data.pages.size() < 1048576 && // 1MB limit
             (!('thumbnail' in data) || data.thumbnail == null || (data.thumbnail is string && data.thumbnail.size() < 1048576)) &&
             (!('currentStep' in data) || data.currentStep == null || (data.currentStep is string && data.currentStep.size() < 100)) &&
             (!('fullScript' in data) || data.fullScript == null || (data.fullScript is string && data.fullScript.size() < 1048576)) &&
             (!('activityScript' in data) || data.activityScript == null || (data.activityScript is string && data.activityScript.size() < 1048576)) &&
             (!('nicheTopic' in data) || data.nicheTopic == null || (data.nicheTopic is string && data.nicheTopic.size() < 1000)) &&
             (!('nicheResult' in data) || data.nicheResult == null || (data.nicheResult is string && data.nicheResult.size() < 1048576)) &&
             (!('coverImage' in data) || data.coverImage == null || (data.coverImage is string && data.coverImage.size() < 1048576)) &&
             (!('coverLayers' in data) || data.coverLayers == null || (data.coverLayers is string && data.coverLayers.size() < 1048576)) &&
             (!('projectContext' in data) || data.projectContext == null || (data.projectContext is string && data.projectContext.size() < 1048576)) &&
             (!('enableActivityDesigner' in data) || data.enableActivityDesigner == null || data.enableActivityDesigner is bool) &&
             (!('globalFixPrompt' in data) || data.globalFixPrompt == null || (data.globalFixPrompt is string && data.globalFixPrompt.size() < 1048576)) &&
             (!('targetAspectRatio' in data) || data.targetAspectRatio == null || (data.targetAspectRatio is string && data.targetAspectRatio.size() < 100)) &&
             (!('targetResolution' in data) || data.targetResolution == null || (data.targetResolution is string && data.targetResolution.size() < 100));
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() && isValidProject(request.resource.data) && uidUnchanged() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidProject(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
