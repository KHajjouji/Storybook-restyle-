{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A StoryFlow project containing settings and pages.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the project."
        },
        "uid": {
          "type": "string",
          "description": "The user ID of the owner."
        },
        "name": {
          "type": "string",
          "description": "Name of the project."
        },
        "lastModified": {
          "type": "number",
          "description": "Timestamp of last modification."
        },
        "settings": {
          "type": "string",
          "description": "JSON stringified settings."
        },
        "pages": {
          "type": "string",
          "description": "JSON stringified pages."
        },
        "thumbnail": {
          "type": "string",
          "description": "Thumbnail image base64."
        }
      },
      "required": ["id", "uid", "name", "lastModified", "settings", "pages"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "User projects."
    }
  }
}
