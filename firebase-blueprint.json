{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A StoryFlow project containing settings and pages.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the project."
        },
        "uid": {
          "type": "string",
          "description": "The user ID of the owner."
        },
        "name": {
          "type": "string",
          "description": "Name of the project."
        },
        "lastModified": {
          "type": "number",
          "description": "Timestamp of last modification."
        },
        "settings": {
          "type": "string",
          "description": "JSON stringified settings."
        },
        "pages": {
          "type": "string",
          "description": "JSON stringified pages."
        },
        "thumbnail": {
          "type": "string",
          "description": "Thumbnail image base64."
        },
        "currentStep": {
          "type": "string",
          "description": "The current step the user is on."
        },
        "fullScript": {
          "type": "string",
          "description": "The full script of the story."
        },
        "activityScript": {
          "type": "string",
          "description": "The activity script."
        },
        "nicheTopic": {
          "type": "string",
          "description": "The niche topic being researched."
        },
        "nicheResult": {
          "type": "string",
          "description": "The result of the niche research."
        },
        "coverImage": {
          "type": "string",
          "description": "The generated cover image base64."
        },
        "coverLayers": {
          "type": "string",
          "description": "JSON stringified cover layers."
        },
        "projectContext": {
          "type": "string",
          "description": "The project context."
        },
        "enableActivityDesigner": {
          "type": "boolean",
          "description": "Whether the activity designer is enabled."
        },
        "globalFixPrompt": {
          "type": "string",
          "description": "The global fix prompt."
        },
        "targetAspectRatio": {
          "type": "string",
          "description": "The target aspect ratio."
        },
        "targetResolution": {
          "type": "string",
          "description": "The target resolution."
        }
      },
      "required": ["id", "uid", "name", "lastModified", "settings", "pages"]
    },
    "UserStyle": {
      "title": "UserStyle",
      "description": "A custom style saved by the user.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the style."
        },
        "uid": {
          "type": "string",
          "description": "The user ID of the owner."
        },
        "name": {
          "type": "string",
          "description": "Name of the style."
        },
        "image": {
          "type": "string",
          "description": "Base64 image of the style."
        },
        "prompt": {
          "type": "string",
          "description": "The style prompt."
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of creation."
        }
      },
      "required": ["id", "uid", "name", "image", "prompt", "createdAt"]
    },
    "AllowedEmail": {
      "title": "AllowedEmail",
      "description": "An email address allowed to sign in to the app.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The allowed email address."
        },
        "role": {
          "type": "string",
          "description": "The role of the user, e.g., 'admin' or 'user'."
        },
        "tierId": {
          "type": "string",
          "description": "The tier assigned to this user."
        },
        "addedBy": {
          "type": "string",
          "description": "The UID of the admin who added this email."
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when the email was added."
        }
      },
      "required": ["email", "role", "addedBy", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including credits and tier.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user ID."
        },
        "email": {
          "type": "string",
          "description": "The user's email."
        },
        "tierId": {
          "type": "string",
          "description": "The ID of the tier the user is on."
        },
        "credits": {
          "type": "number",
          "description": "The user's current API credit balance."
        },
        "role": {
          "type": "string",
          "description": "The user's role (admin or user)."
        }
      },
      "required": ["uid", "email", "credits", "role"]
    },
    "Tier": {
      "title": "Tier",
      "description": "Subscription tier or plan.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the tier."
        },
        "name": {
          "type": "string",
          "description": "Name of the tier."
        },
        "maxProjects": {
          "type": "number",
          "description": "Maximum number of saved projects allowed."
        },
        "monthlyCredits": {
          "type": "number",
          "description": "Number of credits allocated monthly."
        }
      },
      "required": ["id", "name", "maxProjects", "monthlyCredits"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "User projects."
    },
    "userStyles/{styleId}": {
      "schema": "UserStyle",
      "description": "User custom styles."
    },
    "allowedEmails/{emailId}": {
      "schema": "AllowedEmail",
      "description": "Emails allowed to access the app."
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles."
    },
    "tiers/{tierId}": {
      "schema": "Tier",
      "description": "Subscription tiers."
    }
  }
}
